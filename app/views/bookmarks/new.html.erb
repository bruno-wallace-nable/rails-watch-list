<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-6">
      <h1>Add a movie to <%= @list.name %></h1>

      <%= simple_form_for([@list, @bookmark]) do |f| %>
        <%= f.association :movie, prompt: "Choose a movie", input_html: { class: "select2" } %>
        <%= f.input :comment, placeholder: "Enter a short comment" %>

        <%= f.submit "Add movie", class: "btn btn-primary" %>
        <%= link_to "Cancel", list_path(@list), class: "btn btn-light ms-2" %>
      <% end %>
    </div>
  </div>
</div>
