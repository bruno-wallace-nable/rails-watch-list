<div class="container py-5">
  <h1><%= @list.name %></h1>

  <div class="row mt-4">
    <% @list.bookmarks.each do |bookmark| %>
      <div class="col-12 col-md-6 mb-3">
        <div class="card d-flex flex-row p-3 shadow-sm">
          <img src="<%= bookmark.movie.poster_url %>" alt="<%= bookmark.movie.title %>" style="width: 100px; height: 150px; object-fit: cover;">
          <div class="ms-3">
            <h5><%= bookmark.movie.title %> <span class="badge bg-warning"><%= bookmark.movie.rating %></span></h5>
            <p><%= bookmark.movie.overview %></p>
            <em class="text-muted">"<%= bookmark.comment %>"</em>
            <div class="mt-2">
              <%= link_to "Remove", bookmark_path(bookmark),
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                  class: "text-danger" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-5">
    <%= link_to "Add a movie", new_list_bookmark_path(@list), class: "btn btn-success" %>
    <%= link_to "Back to all lists", lists_path, class: "btn btn-outline-secondary ms-2" %>
  </div>
</div>
