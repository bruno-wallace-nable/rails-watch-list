<div class="banner mb-5" style="background-image: linear-gradient(rgba(0,0,0,0.4),rgba(0,0,0,0.4)), url(https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80);">
  <div class="container text-center">
    <h1>Save any kind of movies</h1>
    <p>From drama to sci-fi, keep your favorites in one place.</p>
    <%= link_to "Create a list", new_list_path, class: "btn btn-flat" %>
  </div>
</div>
<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Movie Lists</h2>
  </div>

  <div class="row">
    <% @lists.each do |list| %>
      <div class="col-12 col-md-4 mb-3">
        <div class="card p-3 shadow-sm">
          <h3><%= link_to list.name, list_path(list), class: "text-decoration-none" %></h3>
          <p class="text-muted"><%= list.movies.count %> movies</p>
        </div>
      </div>
    <% end %>
  </div>
</div>
